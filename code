void userInputs(double& airTemp, double& windSpeed, double& dewPoint) { //all user inputs
    cout << "\nWhat is the temperature in degrees farenheit?  ";
    cin >> airTemp;
    while (!airTemp) { //invalid input/fail check for air temperature
        cout << "Invalid input, please enter your temperature.  ";
        cin.clear();
        cin.ignore(10000, '\n');
        cin >> airTemp;
    }
    
    cout << "\nWhat is the wind speed in MPH?  ";
    cin >> windSpeed;
    while (!windSpeed) { //invalid input/fail check for wind speed
        cout << "Invalid input, please enter your wind speed.  ";
        cin.clear();
        cin.ignore(10000, '\n');
        cin >> windSpeed;
    }
    
    cout << "\nWhat is the dew point?  ";
    cin >> dewPoint;
    while (!dewPoint) { //invalid input/fail check for dew point
        cout << "Invalid input, please enter your dew point.  ";
        cin.clear();
        cin.ignore(10000, '\n');
        cin >> dewPoint;
    }
}

void weatherCalculations(double& airTemp, double& windSpeed, double& dewPoint, double& windChill, double& cloudBase)  {
    windChill = 35.74 + (0.6215*airTemp) - (37.75 * pow(windSpeed, 0.16)) + (0.4275 * airTemp * pow(windSpeed, 0.16)); //proper calculations for wind chill, sectioned off and done using PEMDAS properly
    cloudBase = 1000*((airTemp-dewPoint)/4.4); //proper calculations for cloud base
}

void weatherDisplay(double& airTemp, double& windSpeed, double& dewPoint, double& windChill, double& cloudBase) { //final little display, showing all info gathered throughout the entirety of the program
    cout << "------------------------------------------------------------------" << endl;
    cout << "|   Wind Chill   |     " << windChill << endl;
    cout << "------------------------------------------------------------------" << endl;
    cout << "|   Cloud Base   |     " << cloudBase << endl;
    cout << "------------------------------------------------------------------" << endl;
    cout << "|   Temperature  |     " << airTemp << endl;
    cout << "------------------------------------------------------------------" << endl;
    cout << "|   Wind Speed   |     " << windSpeed << endl;
    cout << "------------------------------------------------------------------" << endl;
    cout << "|   Dew Point    |     " << dewPoint << endl;
    cout << "------------------------------------------------------------------" << endl;
}
